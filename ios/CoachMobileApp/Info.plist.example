<dict>
	<key>NSMicrophoneUsageDescription</key>
	<string>Coach needs microphone access to record your speaking practice.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Coach uses speech recognition to transcribe your recordings for rewriting and coaching.</string>
</dict>
</plist>